# ╔══════════════════════════════════════════════════════════╗
# ║  Project Automatron — Environment Variables             ║
# ╚══════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in the values.

# ── LLM API Keys ───────────────────────────────────────────
# At least one must be set. Keys are also injected via Docker Secrets.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# ── LLM Models ─────────────────────────────────────────────
ARCHITECT_MODEL=anthropic/claude-sonnet-4-20250514
BUILDER_MODEL=anthropic/claude-sonnet-4-20250514
REVIEWER_MODEL=openai/gpt-4.1-mini

# ── Database ───────────────────────────────────────────────
SQLITE_DB_PATH=./data/automatron.db
CHECKPOINT_DB_PATH=./data/checkpoints.db

# ── Docker ─────────────────────────────────────────────────
GOLDEN_IMAGE=automatron/golden:latest
WORKSPACE_BASE_PATH=/var/automatron/workspaces
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_LIMIT=2.0

# ── Port Allocation ───────────────────────────────────────
PORT_RANGE_START=7000
PORT_RANGE_END=7999

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Builder ────────────────────────────────────────────────
CLINE_TIMEOUT=300
MAX_ESCALATIONS=2
